{
  "productName": "Pluely",
  "version": "0.1.9",
  "identifier": "pluely",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Pluely - AI Assistant",
        "width": 600,
        "height": 600,
        "decorations": true,
        "transparent": false,
        "theme": "Dark",
        "backgroundColor": "#000000",
        "alwaysOnTop": true,
        "resizable": true,
        "visibleOnAllWorkspaces": true,
        "skipTaskbar": true,
        "visible": true,
        "center": false,
        "contentProtected": false,
        "focus": true,
        "acceptFirstMouse": true,
        "shadow": false
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "targets": "deb",
    "icon": ["icons/128x128.png"],
    "resources": ["pluely.desktop"]
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:pluely.db"]
    }
  }
}